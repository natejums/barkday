{
  "name": "barkday",
  "version": "0.3.0",
  "private": false,
  "description": "An evidence-based dog age calculator that models size, breed, body condition and lifestyle — not just \"multiply by seven\".",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "dog",
    "dog-age",
    "dog-years",
    "veterinary",
    "calculator",
    "pets",
    "typescript",
    "react"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
